@model Country.MVC.Models.Country.CountryViewModel

@{
    ViewData["Title"] = "Country Details";
}

<h1>Country Details</h1>

<dl class="row">
    <dt class="col-sm-2">@Html.DisplayNameFor(m => m.Id)</dt>
    <dd class="col-sm-10">@Html.DisplayFor(m => m.Id)</dd>

    <dt class="col-sm-2">@Html.DisplayNameFor(m => m.Name)</dt>
    <dd class="col-sm-10">@Html.DisplayFor(m => m.Name)</dd>

    <dt class="col-sm-2">@Html.DisplayNameFor(m => m.ShortDesc)</dt>
    <dd class="col-sm-10">@Html.DisplayFor(m => m.ShortDesc)</dd>

    <dt class="col-sm-2">@Html.DisplayNameFor(m => m.CountryCode)</dt>
    <dd class="col-sm-10">@Html.DisplayFor(m => m.CountryCode)</dd>
</dl>

<div class="mt-2">
    <a asp-action="Edit" asp-route-id="@Model.Id" class="btn btn-warning">Edit</a>
    <a asp-action="Index" class="btn btn-secondary">Back to List</a>
</div>